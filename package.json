{
  "name": "spawner",
  "version": "1.0.0",
  "description": "Docker container spawner for devops game",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node --require tsx/cjs ./node_modules/.bin/knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "node --require tsx/cjs ./node_modules/.bin/knex --knexfile knexfile.ts migrate:rollback"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/websocket": "^11.0.2",
    "http-proxy": "^1.18.1",
    "mysql2": "^3.14.0",
    "dockerode": "^4.0.4",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.2",
    "knex": "^3.1.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.35",
    "@types/http-proxy": "^1.17.16",
    "@types/node": "^22.14.0",
    "@types/ssh2": "^1.15.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
