# Server
PORT=3001
HOST=0.0.0.0

# The public IP/hostname of this spawner machine
# The backend uses this to route SSH/HTTP traffic to containers
WORKER_PUBLIC_IP=127.0.0.1

# API key — backend must send this in the X-API-Key header
API_KEY=change-me

# MariaDB connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=spawner
DB_PASSWORD=
DB_NAME=spawner

# Proxy server — receives traffic forwarded by nginx for *.nuazi.ro
PROXY_PORT=3002

# Base domain used for building external URLs in the domain routes API
BASE_DOMAIN=nuazi.ro

# Optional: override Docker socket path (auto-detected if not set)
# DOCKER_SOCKET=/var/run/docker.sock

# Set to true to keep stopped containers alive for debugging
# DEBUG_KEEP_CONTAINERS=false

# Tuning (milliseconds)
# PORT_BINDING_WAIT_MS=15000
# PORT_BINDING_POLL_MS=200
# CONTAINER_READY_WAIT_MS=30000
